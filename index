<!DOCTYPE html>
<html>
<head>
    <title>My Task App</title>
</head>
<body>
    <h1>Welcome to My Task Tracker</h1>
    <p>This is my first website. It helps track tasks for youth working from home.</p>

    <h2>Create a Task</h2>
    <form>
        <label>Task Name:</label>
        <input type="text" name="taskname"><br><br>

        <label>Assigned To:</label>
        <input type="text" name="assignee"><br><br>

        <label>Deadline:</label>
        <input type="date" name="deadline"><br><br>

        <input type="submit" value="Add Task">
    </form>

    <h2>To-Do List</h2>
    <ul>
        <li>Example Task 1 - Assigned to Sarah - Due tomorrow</li>
        <li>Example Task 2 - Assigned to John - Due next week</li>
    </ul>

    <h2>Notifications</h2>
    <p>New task added! Don’t forget to finish your work.</p>
</body>
</html>






<form id="taskForm">
  <input type="text" id="title" placeholder="Task Title" required><br>
  <textarea id="description" placeholder="Task Description"></textarea><br>
  <input type="text" id="assignee" placeholder="Assign To" required><br>
  <input type="date" id="deadline" required><br>
  <button type="submit">Create Task</button>
</form>
